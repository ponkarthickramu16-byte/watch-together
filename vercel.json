{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "framework": "vite",
    "functions": {
        "api/token.js": {
            "memory": 512,
            "maxDuration": 10
        }
    },
    "routes": [
        {
            "src": "/api/token",
            "dest": "/api/token.js"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ]
}