rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /rooms/{docId} {
      allow read, create, update: if request.auth != null;
      allow delete: if false;
    }

    match /chats/{docId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.username is string
        && request.resource.data.username.size() > 0;

      allow update: if request.auth != null && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy'])
        ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['message', 'editedAt'])
      );

      allow delete: if request.auth != null;
    }

    match /reactions/{docId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.roomId is string
        && request.resource.data.emoji is string;

      allow update: if false;
      allow delete: if request.auth != null;
    }

    match /watchHistory/{docId} {

      // ✅ Read only your own history (supports old + new data)
      allow read: if request.auth != null && (
        (resource.data.watchedByUid is string && resource.data.watchedByUid == request.auth.uid)
        ||
        (resource.data.watchedByUid == null && resource.data.watchedBy is string && (
          (request.auth.token.email is string && resource.data.watchedBy == request.auth.token.email)
          ||
          (request.auth.token.name is string && resource.data.watchedBy == request.auth.token.name)
        ))
      );

      // ✅ Create only your own
      allow create: if request.auth != null
        && request.resource.data.watchedByUid == request.auth.uid;

      // ✅ Delete only your own (added from second rule)
      allow delete: if request.auth != null
        && resource.data.watchedByUid == request.auth.uid;

      allow update: if false;
    }

    match /fcmTokens/{docId} {
      allow read, write: if request.auth != null;
    }

    match /profiles/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ❌ Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
